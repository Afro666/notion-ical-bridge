# notion-ical-bridge environment variables
# Copy this file to `.env` and fill in real values.
# `.env` is gitignored; never commit real tokens.

# Notion integration token.
# Create one at https://www.notion.com/my-integrations
# Tokens look like `secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx`
# or `ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx`.
NOTION_TOKEN=secret_REPLACE_ME

# Server bind address and port.
# HOST=0.0.0.0 binds all interfaces (required inside Docker).
HOST=0.0.0.0
PORT=3000

# Runtime mode. `production` switches Fastify's pino logger to JSON output.
NODE_ENV=production

# Logger verbosity: trace | debug | info | warn | error | fatal | silent
LOG_LEVEL=info

# Path to the calendar config file.
# In Docker this is typically /app/config.yaml mounted from the host.
CONFIG_PATH=./config.yaml

# --- Optional: per-calendar Notion tokens ---
# config.yaml may reference env vars like ${NOTION_TOKEN_SISTERHOOD}
# to use a different integration for a specific calendar.
# NOTION_TOKEN_SISTERHOOD=secret_REPLACE_ME
